# Release automation for Tone.
#
# Auth uses an App Store Connect API key (.p8) — no Apple ID password, no 2FA, and
# no expiring session. The key replaces BOTH spaceauth and the app-specific password.
#
# One-time setup (App Store Connect → Users and Access → Integrations →
#   App Store Connect API): generate a Team key with the **App Manager** role,
#   download `AuthKey_XXXXXXXXXX.p8` (downloadable once), and note the Key ID +
#   Issuer ID (Issuer ID is shown at the top of the Keys page).
#
# Then export (nothing secret is committed — values live in env / a gitignored .env):
#   export DEVELOPMENT_TEAM=XXXXXXXXXX                  # 10-char Team ID
#   export ASC_KEY_ID=XXXXXXXXXX                        # the key's Key ID
#   export ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx   # Issuer ID
#   export ASC_KEY_FILEPATH="$HOME/.private_keys/AuthKey_XXXXXXXXXX.p8"  # path to the .p8
#
# Then: `bundle exec fastlane release`  (or `fastlane release`)

default_platform(:ios)

APP_ID = "com.yutabee.tone"

def require_env!(keys)
  missing = keys.reject { |k| ENV[k] && !ENV[k].empty? }
  UI.user_error!("Missing env: #{missing.join(', ')} — see the header of fastlane/Fastfile") unless missing.empty?
end

# App Store Connect API key, loaded from env. Used by every lane that talks to
# App Store Connect (produce / deliver / pilot) and for signing during archive.
def asc_api_key
  require_env!(%w[ASC_KEY_ID ASC_ISSUER_ID ASC_KEY_FILEPATH])
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ENV.fetch("ASC_KEY_FILEPATH")
  )
end

platform :ios do
  desc "Regenerate the Xcode project and archive a signed App Store .ipa"
  # 署名は手動(manual)。事前に作成・インストール済みの配布アセットを使う:
  #   - 証明書: "Apple Distribution: <name> (<team id>)"(login keychain)
  #   - プロファイル: "Tone App Store"(App Store / com.yutabee.tone)
  # クラウド署名(API キーで証明書を自動生成)は API キーの App Manager ロールでは
  # 証明書を作成できず exportArchive で失敗するため、明示 manual 署名に倒している。
  # archive 段の署名設定は project.yml の Tone ターゲット Release config が持つ
  # (xcargs でグローバル指定すると SPM 依存にも波及し archive が失敗するため)。
  # この lane は export 段の署名のみ export_options で manual 指定する。
  PROVISIONING_PROFILE_NAME = "Tone App Store"
  lane :build do
    require_env!(%w[DEVELOPMENT_TEAM])
    team = ENV.fetch("DEVELOPMENT_TEAM")
    sh("cd .. && xcodegen generate")
    # CI が BUILD_NUMBER を渡したらビルド番号を上書きする(ローカルは project.yml の値のまま)。
    # 署名 arg と違いバージョン値は SPM 依存へ波及しても無害(provisioning エラーにはならない)。
    build_number_args = ENV["BUILD_NUMBER"] ? "CURRENT_PROJECT_VERSION=#{ENV['BUILD_NUMBER']}" : nil
    build_app(
      project: "Tone.xcodeproj",
      scheme: "Tone",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build/export",
      output_name: "Tone.ipa",
      xcargs: build_number_args,
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: team,
        provisioningProfiles: {
          APP_ID => PROVISIONING_PROFILE_NAME
        }
      }
    )
  end

  # CI 用: TestFlight の最新ビルド番号 +1 を算出し BUILD_NUMBER として GITHUB_ENV へ書き出す。
  # これで手動採番(project.yml)に頼らず番号衝突を防ぐ(過去に 1.0.0=build4 と衝突した教訓)。
  desc "Compute next build number (latest TestFlight build + 1), export BUILD_NUMBER to CI env"
  lane :next_build_number do
    # 一時的な API エラーを握り潰さない: `rescue 0` だと latest=0→n=1 になり既存ビルドと
    # 衝突する(ITMS-4238)。「ビルド未存在」だけ initial_build_number で安全に 0 とし、
    # 認証/通信エラー等はそのまま fail させる(誤った番号でアップロードするより止める)。
    latest = latest_testflight_build_number(
      app_identifier: APP_ID,
      api_key: asc_api_key,
      initial_build_number: 0
    )
    n = latest.to_i + 1
    UI.message("Next build number: #{n} (latest on TestFlight: #{latest})")
    File.open(ENV["GITHUB_ENV"], "a") { |f| f.puts("BUILD_NUMBER=#{n}") } if ENV["GITHUB_ENV"]
    n
  end

  # NOTE: creating the app record is a ONE-TIME manual step in App Store Connect.
  # `produce` / devcenter do NOT support App Store Connect API-key auth (they need an
  # Apple ID session), so we do not automate creation. Everything AFTER the app exists
  # (metadata / build upload / TestFlight / submit) runs fully on the API key.
  desc "Print the one-time app-creation checklist (produce can't use API-key auth)"
  lane :ensure_app do
    UI.message("One-time: App Store Connect → Apps → + → New App")
    UI.message("  Bundle ID: #{APP_ID}  ·  Platform: iOS  ·  SKU: tone-ios-1")
    UI.message("Register the App ID at developer.apple.com/account/resources/identifiers first.")
    UI.message("Once the app exists, run `fastlane metadata` / `fastlane beta` / `fastlane release`.")
  end

  desc "Upload metadata + screenshots only (no binary, no submit)"
  lane :metadata do
    upload_to_app_store(
      app_identifier: APP_ID,
      api_key: asc_api_key,
      skip_binary_upload: true,
      overwrite_screenshots: true,
      submit_for_review: false,
      force: true,
      precheck_include_in_app_purchases: false,
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots"
    )
  end

  desc "Build + upload to TestFlight (no public release)"
  lane :beta do
    build
    upload_to_testflight(app_identifier: APP_ID, api_key: asc_api_key, skip_waiting_for_build_processing: true)
  end

  # Submit the build that is ALREADY uploaded (e.g. via `beta`) for review, without
  # rebuilding. Rebuilding would re-upload the same build number and collide, so the
  # auto-publish path reuses the processed TestFlight build. After Apple approves it
  # releases automatically (no human "Release" click).
  desc "Submit the latest uploaded build for review + auto-release after approval (no rebuild)"
  lane :submit do
    upload_to_app_store(
      app_identifier: APP_ID,
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      force: true,
      submit_for_review: true,
      automatic_release: true,           # Apple 承認後に自動公開(人手の Release クリック不要)
      precheck_include_in_app_purchases: false,
      submission_information: {
        export_compliance_uses_encryption: false,
        add_id_info_uses_idfa: false
      }
    )
  end

  desc "FULL: ensure app → build+sign → upload binary + metadata + screenshots → submit for review"
  lane :release do
    require_env!(%w[DEVELOPMENT_TEAM ASC_KEY_ID ASC_ISSUER_ID ASC_KEY_FILEPATH])
    # The app record must already exist (see `fastlane ensure_app` for the one-time steps).
    build
    upload_to_app_store(
      app_identifier: APP_ID,
      api_key: asc_api_key,
      ipa: "build/export/Tone.ipa",
      force: true,                       # skip the HTML preview/confirm
      overwrite_screenshots: true,
      submit_for_review: true,           # ← irreversible; gate this in your runbook
      automatic_release: false,          # 承認後の公開は人手で(自動公開は submit lane 側)
      precheck_include_in_app_purchases: false,
      submission_information: {
        export_compliance_uses_encryption: false,
        add_id_info_uses_idfa: false
      },
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots"
    )
  end
end
